# ── Database ──────────────────────────────────────────────────────────────────
# asyncpg driver used by FastAPI + worker. Alembic translates this to psycopg
# automatically.
DATABASE_URL=postgresql+asyncpg://syllabus:syllabus@localhost:5432/syllabus

# ── Redis ─────────────────────────────────────────────────────────────────────
# Used for: arq queue, slowapi rate-limit storage, per-IP active-job slots,
# and the per-job state blobs the frontend polls.
REDIS_URL=redis://localhost:6379/0

# ── Job state TTL ─────────────────────────────────────────────────────────────
# How long /jobs/<id> remembers a finished job.
JOB_STATE_TTL_SECONDS=86400

# ── Extraction ────────────────────────────────────────────────────────────────
# Hard ceiling on Docling extraction inside the worker.
DOCLING_TIMEOUT_SECONDS=500

# Where the API drops uploaded PDFs for the worker to pick up. Must be
# readable+writable by both processes. On a single host, /tmp is fine.
# UPLOAD_TMPDIR=/tmp

# ── /results endpoint ─────────────────────────────────────────────────────────
RESULTS_ENABLED=true
RESULTS_MAX_AGE_HOURS=24

# ── Synchronous fallback ──────────────────────────────────────────────────────
# Set to false in production to disable the legacy /upload-sync route.
UPLOAD_SYNC_ENABLED=true

# ── Ollama (existing) ─────────────────────────────────────────────────────────
# These are read by parser.py via constants.py — values live there. Add them
# here only if you want to override at deploy time.
# OLLAMA_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.1:8b
# OLLAMA_TIMEOUT=300
