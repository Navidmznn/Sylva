# ── Database ──────────────────────────────────────────────────────────────────
# asyncpg driver used by FastAPI + worker. Alembic translates this to psycopg
# automatically.
DATABASE_URL=postgresql+asyncpg://syllabus:syllabus@localhost:5432/syllabus

# ── Redis ─────────────────────────────────────────────────────────────────────
# Used for: arq queue, slowapi rate-limit storage, per-IP active-job slots,
# and the per-job state blobs the frontend polls.
REDIS_URL=redis://localhost:6379/0

# ── Job state TTL ─────────────────────────────────────────────────────────────
# How long /jobs/<id> remembers a finished job.
JOB_STATE_TTL_SECONDS=86400

# ── Extraction ────────────────────────────────────────────────────────────────
# Hard ceiling on Docling extraction inside the worker.
DOCLING_TIMEOUT_SECONDS=500

# Where the API drops uploaded PDFs for the worker to pick up. Must be
# readable+writable by both processes. On a single host, /tmp is fine.
# UPLOAD_TMPDIR=/tmp

# ── /results endpoint ─────────────────────────────────────────────────────────
RESULTS_ENABLED=true
RESULTS_MAX_AGE_HOURS=24

# ── Synchronous fallback ──────────────────────────────────────────────────────
# Set to false in production to disable the legacy /upload-sync route.
UPLOAD_SYNC_ENABLED=true

# ── Ollama (existing) ─────────────────────────────────────────────────────────
# These are read by parser.py via constants.py — values live there. Add them
# here only if you want to override at deploy time.
# OLLAMA_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.1:8b
# OLLAMA_TIMEOUT=300

# ── Auth (NEW) ────────────────────────────────────────────────────────────────
# REQUIRED in production. Used as the HMAC key for hashing magic-link tokens
# and session tokens. Rotating this value invalidates all live tokens.
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
SESSION_SECRET=

# Cookie attributes. Defaults are dev-friendly:
#   COOKIE_SECURE=false   ← localhost has no HTTPS; set to "true" in prod.
#   COOKIE_SAMESITE=lax   ← set to "strict" in prod for stronger CSRF posture.
COOKIE_SECURE=false
COOKIE_SAMESITE=lax

# Where to redirect the user after a successful magic-link click. Must include
# scheme + host + (optional) port — no trailing slash. Also used by CORS as
# the single allowed origin (allow_credentials requires an exact origin).
FRONTEND_ORIGIN=http://localhost:5500

# Public URL of THIS backend, used to build the magic link in emails.
BACKEND_BASE_URL=http://localhost:8000

# Token lifetimes.
MAGIC_LINK_TTL_MINUTES=15
SESSION_TTL_DAYS=30

# Set to "production" to make missing SESSION_SECRET a hard error at boot.
ENVIRONMENT=development

# ── Email (NEW) ───────────────────────────────────────────────────────────────
# EMAIL_MODE=console (default for dev) prints the magic link to the API's
# stdout. EMAIL_MODE=smtp uses the credentials below to send real email.
EMAIL_MODE=console

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=no-reply@syllabus.local
SMTP_USE_TLS=true
