# database
# alembic auto-translates +asyncpg to +psycopg for migrations
DATABASE_URL=postgresql+asyncpg://syllabus:syllabus@localhost:5432/syllabus

# redis — used by arq, slowapi, job state, and per-IP slots
REDIS_URL=redis://localhost:6379/0

# how long a finished job stays visible at /jobs/<id>
JOB_STATE_TTL_SECONDS=86400

# extraction
DOCLING_TIMEOUT_SECONDS=500

# where uploads land before the worker picks them up — /tmp is fine on a single host
# UPLOAD_TMPDIR=/tmp

RESULTS_ENABLED=true
RESULTS_MAX_AGE_HOURS=24

# set to false in prod to disable the legacy /upload-sync route
UPLOAD_SYNC_ENABLED=true

# ollama — override here if you want a different model/URL at deploy time
# OLLAMA_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.1:8b
# OLLAMA_TIMEOUT=300

# auth
# required in prod — HMAC key for tokens. rotating this invalidates all sessions.
# generate: python -c "import secrets; print(secrets.token_urlsafe(48))"
SESSION_SECRET=

# set secure=true and samesite=strict in prod
COOKIE_SECURE=false
COOKIE_SAMESITE=lax

# used for CORS and magic-link redirects
FRONTEND_ORIGIN=http://localhost:5500
BACKEND_BASE_URL=http://localhost:8000

MAGIC_LINK_TTL_MINUTES=15
SESSION_TTL_DAYS=30

# set to "production" to make missing SESSION_SECRET a hard error at boot
ENVIRONMENT=development

# email
# console (default) prints the magic link to stdout; smtp sends real email
EMAIL_MODE=console

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=no-reply@syllabus.local
SMTP_USE_TLS=true
