# ─────────────────────────────────────────────────────────────────────────────
# syllabus.ai — .gitignore
# ─────────────────────────────────────────────────────────────────────────────


# ── Python — compiled / cache ─────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
*.pyo
.Python


# ── Python — virtual environments ────────────────────────────────────────────
.venv/
venv/
env/
ENV/


# ── Python — package / distribution artifacts ────────────────────────────────
*.egg
*.egg-info/
dist/
build/
eggs/
wheels/


# ── Python — testing / coverage ──────────────────────────────────────────────
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/


# ── Python — type checking / linting caches ──────────────────────────────────
.mypy_cache/
.ruff_cache/
.dmypy.json


# ── Databases / data ─────────────────────────────────────────────────────────
*.db
*.sqlite
*.sqlite3
results.db


# ── Environment / secrets ────────────────────────────────────────────────────
.env
.env.*
!.env.example


# ── Uploaded / generated files ───────────────────────────────────────────────
*.pdf
uploads/
tmp/


# ── Project-specific ─────────────────────────────────────────────────────────
Modelfile


# ── IDE / editors ────────────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
*.swn
*~


# ── OS ───────────────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini


# ── Logs ─────────────────────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*


# ── Node (if a frontend build step is ever added) ────────────────────────────
node_modules/
.npm
.yarn/
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/sdks
!.yarn/versions


# ── Frontend build outputs (if a build step is ever added) ───────────────────
.cache/
.parcel-cache/
.next/
out/
